{
  "name": "khora-online",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest --run",
    "lint": "eslint packages/*/src/**/*.ts",
    "dev:server": "npm run start --workspace=packages/server",
    "dev:client": "npm run dev --workspace=packages/client"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.22.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
